{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile in the application.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "coach"] },
        "points": { "type": "number" },
        "tier": { "type": "string" },
        "avatar": { "type": "string" },
        "coachId": { "type": "string" },
        "heightCm": { "type": "number" },
        "birthday": { "type": "string" },
        "targetWeightKg": { "type": "number" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["name", "email", "role", "points", "createdAt"]
    },
    "Exercise": {
      "title": "Exercise",
      "description": "An exercise within a workout.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sets": { "type": "number" },
        "reps": { "type": "string" },
        "weight": { "type": "string" },
        "restSeconds": { "type": "number" },
        "muscleGroup": { "type": "string" },
        "difficulty": { "type": "string" },
        "purpose": { "type": "string" },
        "instructions": { "type": "string" }
      },
      "required": ["id", "name", "sets", "reps", "weight", "restSeconds", "muscleGroup"]
    },
    "Workout": {
      "title": "Workout",
      "description": "A customized workout or challenge assigned to a student.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "authorId": { "type": "string" },
        "studentId": { "type": "string" },
        "type": { "type": "string", "enum": ["regular", "challenge"] },
        "points": { "type": "number" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "timestamp" },
        "expiresAt": { "type": "string", "format": "timestamp" },
        "exercises": { 
          "type": "array",
          "items": { "$ref": "#/entities/Exercise" }
        }
      },
      "required": ["title", "authorId", "studentId", "completed", "createdAt", "exercises"]
    },
    "Session": {
      "title": "Workout Session",
      "description": "A completed log of a workout.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "workoutId": { "type": "string" },
        "coachId": { "type": "string" },
        "durationSeconds": { "type": "number" },
        "rpe": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["studentId", "workoutId", "durationSeconds", "rpe", "createdAt", "coachId"]
    },
    "CheckIn": {
      "title": "Check In",
      "description": "Weekly tracking for a student.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "coachId": { "type": "string" },
        "weightKg": { "type": "number" },
        "targetWeightKg": { "type": "number" },
        "heightCm": { "type": "number" },
        "birthday": { "type": "string" },
        "mood": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["studentId", "weightKg", "createdAt", "coachId", "mood"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message between student and coach.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "receiverId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "report", "checkin"] },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["senderId", "senderName", "receiverId", "content", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Profiles for students and coaches."
    },
    "/workouts/{workoutId}": {
      "schema": { "$ref": "#/entities/Workout" },
      "description": "Workouts assigned by coaches to students."
    },
    "/sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/Session" },
      "description": "Logs of completed workouts."
    },
    "/checkins/{checkInId}": {
      "schema": { "$ref": "#/entities/CheckIn" },
      "description": "Weekly check-in logs with bodyweight and measures."
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Chat messages and automated reports."
    }
  }
}
