rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Identification for the Master Coach - Case insensitive check (manual)
    function isCoach(uid) {
      return request.auth.token.email.matches('(?i)blackwoodstock1985@gmail.com') ||
             (exists(/databases/$(database)/documents/users/$(uid)) && 
              get(/databases/$(database)/documents/users/$(uid)).data.role == 'coach');
    }

    function isOwner(uid) { return request.auth.uid == uid; }

    // --- VALIDATORS ---
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'points', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 150 &&
             data.role is string && (data.role == 'student' || data.role == 'coach') &&
             data.points is number &&
             data.createdAt == request.time;
    }

    function isValidWorkout(data) {
      return data.keys().hasAll(['title', 'authorId', 'assignedTo', 'completed', 'createdAt', 'exercises']) &&
             data.title is string && data.title.size() <= 150 &&
             data.authorId is string && data.authorId == request.auth.uid &&
             data.assignedTo is string && 
             data.completed is bool &&
             data.createdAt == request.time &&
             data.exercises is list;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['studentId', 'workoutId', 'coachId', 'durationSeconds', 'rpe', 'createdAt']) &&
             data.studentId is string && data.studentId == request.auth.uid &&
             data.rpe is number && 
             data.createdAt == request.time;
    }

    // --- RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      
      allow update: if isSignedIn() && (isOwner(userId) || isCoach(request.auth.uid)) &&
        incoming().role == existing().role &&
        incoming().createdAt == existing().createdAt &&
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'points', 'tier', 'coachId', 'id']);
    }

    match /workouts/{workoutId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && isCoach(request.auth.uid) && isValidWorkout(incoming());
      
      allow update: if isSignedIn() && (
        (isCoach(request.auth.uid) && existing().authorId == request.auth.uid) ||
        (existing().assignedTo == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['completed']) && incoming().completed == true)
      );
      
      allow delete: if isSignedIn() && isCoach(request.auth.uid);
    }

    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidSession(incoming());
    }

    match /check_ins/{checkInId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (incoming().studentId == request.auth.uid);
    }
  }
}
