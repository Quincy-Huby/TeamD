rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. BLOQUEIO GLOBAL (Default Denied)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- HELPERS GLOBAIS ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Identificação do Mestre (Admin)
    function isMaster() {
      return isSignedIn() && 
             request.auth.token != null &&
             request.auth.token.get('email', '') != '' &&
             (request.auth.token.get('email', '').matches('(?i)blackwoodstock1985@gmail.com') || request.auth.token.get('email', '').matches('(?i)lucasgab204lgr@gmail.com') || request.auth.token.get('email', '').matches('(?i)rafaelsr1990@gmail.com'));
    }

    // Verifica se o usuário é o dono do documento
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // --- VALIDAÇÕES DE ENTIDADES ---

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'points', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 150 &&
             data.role is string && (data.role == 'student' || data.role == 'coach') &&
             data.points is number &&
             (data.createdAt == request.time || data.createdAt == existing().createdAt);
    }

    function isValidWorkout(data) {
      return data.keys().hasAll(['title', 'authorId', 'studentId', 'completed', 'createdAt', 'exercises']) &&
             data.title is string && data.title.size() <= 200 &&
             data.authorId is string &&
             data.studentId is string && 
             data.completed is bool &&
             data.createdAt == request.time &&
             data.exercises is list &&
             data.exercises.size() <= 50;
    }

    function isValidCheckIn(data) {
      return data.keys().hasAll(['studentId', 'coachId', 'weightKg', 'mood', 'notes', 'createdAt']) &&
             data.studentId is string && data.studentId == request.auth.uid &&
             data.weightKg is number &&
             data.mood is number &&
             data.notes is string && data.notes.size() <= 5000 &&
             data.createdAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'senderName', 'receiverId', 'content', 'type', 'createdAt']) &&
             data.senderId is string && data.senderId == request.auth.uid &&
             data.senderName is string &&
             data.receiverId is string &&
             data.content is string && data.content.size() <= 6000 &&
             data.createdAt == request.time;
    }

    // --- REGRAS POR COLEÇÃO ---

    // Coleção de Usuários
    match /users/{userId} {
      allow get: if true;
      // Permite listagem geral para queries públicas de coaches ou se logado para o ranking
      allow list: if true;
      
      allow create: if isSignedIn() && (isOwner(userId) || isMaster()) && isValidUser(incoming());
      
      allow update: if isSignedIn() && (isOwner(userId) || isMaster()) &&
        incoming().role == existing().role &&
        incoming().createdAt == existing().createdAt &&
        incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'avatar', 'points', 'tier', 'coachId', 'id',
          'heightCm', 'birthday', 'targetWeightKg', 'latestWeightKg', 'lastActiveAt', 'exerciseWeights'
        ]);
    }

    // Coleção de Treinos
    match /workouts/{workoutId} {
      allow read: if isSignedIn() && (isMaster() || resource.data.studentId == request.auth.uid || resource.data.authorId == request.auth.uid);
      allow create: if isSignedIn() && (isMaster() || incoming().authorId == request.auth.uid) && isValidWorkout(incoming());
      
      allow update: if isSignedIn() && (
        isMaster() ||
        (existing().studentId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['completed', 'updatedAt']) && incoming().updatedAt == request.time)
      );
      
      allow delete: if isSignedIn() && (isMaster() || resource.data.authorId == request.auth.uid);
    }

    // Coleção de Check-ins
    match /checkins/{checkInId} {
      allow read: if isSignedIn() && (isMaster() || resource.data.studentId == request.auth.uid || resource.data.coachId == request.auth.uid);
      allow create: if isSignedIn() && isValidCheckIn(incoming());
    }

    // Coleção de Mensagens (Chat)
    match /messages/{messageId} {
      allow read: if isSignedIn() && (isMaster() || resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && isValidMessage(incoming());
    }

    // Coleção de Sessões (Treinos Concluídos)
    match /sessions/{sessionId} {
      allow read: if isSignedIn() && (isMaster() || resource.data.studentId == request.auth.uid || resource.data.coachId == request.auth.uid);
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid;
    }

    // Cache de Mídia (Opcional)
    match /exercise_media_cache/{exerciseId} {
      allow read: if isSignedIn();
      allow write: if isMaster();
    }
  }
}
